---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import contests from "@/data/contests.json";
import VideoEmbed from "@/components/topic/VideoEmbed.astro";
import Image from "@/components/topic/Image.astro";
import ImagesH from "@/components/topic/ImagesH.astro";
import { base } from "@/lib/base";

export async function getStaticPaths() {
  const topics = await getCollection("topics");
  return contests.flatMap((c) =>
    c.topics.map((t) => {
      const entry = topics.find((e) => e.id === t.slug) ?? null;
      return {
        params: { slug: t.slug },
        props: { entry, topic: t, contestNumber: c.number },
      };
    }),
  );
}

const { entry, topic, contestNumber } = Astro.props;

const { Content } = entry ? await render(entry) : { Content: null };
---

<style>
  :global(.dark .prose img) {
    filter: invert(1) hue-rotate(180deg);
  }
</style>

<Layout title={topic.title}>
  <div class="max-w-3xl mx-auto">
    <a
      href={`${base}/topics/${topic.slug}`}
      class="text-sm text-muted-foreground hover:text-primary flex items-center gap-1 mb-8"
    >
      ← Back to {topic.title}
    </a>
    <p class="text-xs font-bold uppercase tracking-widest text-primary mb-2">
      Contest {contestNumber}
    </p>
    <h1 class="text-3xl font-extrabold text-foreground mb-8">{topic.title}</h1>
    <div class="prose prose-invert max-w-none">
      {
        Content ? (
          <Content components={{ VideoEmbed, Image, ImagesH }} />
        ) : (
          <p class="text-muted-foreground">Wiki content coming soon.</p>
        )
      }
    </div>
  </div>
</Layout>
