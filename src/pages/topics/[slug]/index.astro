---
import contests from "@/data/contests.json";
import Layout from "@/layouts/Layout.astro";
import TopicHero from "@/components/topic/TopicHero.astro";
import ResourceLinks from "@/components/topic/ResourceLinks.astro";
import VideoEmbed from "@/components/topic/VideoEmbed.astro";
import { base } from "@/lib/base";

export function getStaticPaths() {
  const topics = contests.flatMap((c) =>
    c.topics.map((t) => ({
      params: { slug: t.slug },
      props: { topic: t, contestNumber: c.number },
    })),
  );
  return topics;
}

const { topic, contestNumber } = Astro.props;
---

<Layout title={topic.title}>
  <div class="max-w-3xl mx-auto">
    <a
      href={`${base}/`}
      class="text-sm text-muted-foreground hover:text-primary flex items-center gap-1 mb-8"
    >
      ← All Contests
    </a>
    <p class="text-xs font-bold uppercase tracking-widest text-primary mb-2">
      Contest {contestNumber}
    </p>
    <TopicHero title={topic.title} explanation={topic.explanation} />
    <ResourceLinks resources={topic.resources} slug={topic.slug} />
    {topic.videoId && <VideoEmbed videoId={topic.videoId} />}
  </div>
</Layout>
